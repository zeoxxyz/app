{
  "name": "luau-obfuscator",
  "version": "0.1.0",
  "description": "Luau parser and obfuscator with full Luau support",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lex": "npm run build && node dist/cli/lex.js",
    "parse": "npm run build && node dist/cli/parse.js",
    "obfuscate": "npm run build && node dist/cli/obfuscate.js",
    "start": "node dist/cli/lex.js"
  },
  "keywords": [
    "luau",
    "obfuscator",
    "parser",
    "roblox"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "@vercel/node": "^5.3.0"
  }
}
